    "@mui/material": "^7.3.10",
    "@mui/x-date-pickers": "^8.28.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@swc/helpers": "^0.5.21",
    "bcryptjs": "^3.0.3",
    "bpmn-auto-layout": "^1.3.0",
    "bpmn-js": "^18.15.0",
    "dayjs": "^1.11.20",
