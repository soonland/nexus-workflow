    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/x-date-pickers": "^8.27.2",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.6.0",
    "@swc/helpers": "^0.5.19",
    "bcryptjs": "^3.0.3",
    "bpmn-auto-layout": "^1.3.0",
    "bpmn-js": "^18.14.0",
    "dayjs": "^1.11.20",
    "dinero.js": "^2.0.2",
    "file-type": "^22.0.0",
