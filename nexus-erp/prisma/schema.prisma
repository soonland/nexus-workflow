generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  employee
  manager
}

enum PermissionType {
  crud
  workflow
}

enum GroupType {
  security
  default
}

enum TimesheetStatus {
  draft
  submitted
  pending_manager_review
  pending_hr_review
  revision_requested
  approved
  rejected
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String            @map("password_hash")
  role         Role
  theme        String?           @default("system")
  locale       String?           @default("fr")
  createdAt    DateTime          @default(now()) @map("created_at")
  employee     Employee?
  permissions  UserPermission[]
  groups       GroupMembership[]

  @@map("users")
}

model Permission {
  key         String               @id
  label       String
  type        PermissionType       @default(workflow)
  users       UserPermission[]
  groups      GroupPermission[]
  departments DepartmentPermission[]

  @@map("permissions")
}

model Group {
  id          String            @id @default(cuid())
  name        String            @unique
  description String?
  type        GroupType         @default(security)
  permissions GroupPermission[]
  members     GroupMembership[]
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@map("groups")
}

model GroupPermission {
  groupId       String     @map("group_id")
  permissionKey String     @map("permission_key")
  group         Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionKey], references: [key], onDelete: Cascade)

  @@id([groupId, permissionKey])
  @@map("group_permissions")
}

model DepartmentPermission {
  departmentId  String     @map("department_id")
  permissionKey String     @map("permission_key")
  department    Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionKey], references: [key], onDelete: Cascade)

  @@id([departmentId, permissionKey])
  @@map("department_permissions")
}

model GroupMembership {
  userId   String   @map("user_id")
  groupId  String   @map("group_id")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now()) @map("joined_at")

  @@id([userId, groupId])
  @@map("group_memberships")
}

model UserPermission {
  userId        String     @map("user_id")
  permissionKey String     @map("permission_key")
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionKey], references: [key], onDelete: Cascade)
  grantedAt     DateTime   @default(now()) @map("granted_at")
  grantedById   String?    @map("granted_by_id")

  @@id([userId, permissionKey])
  @@map("user_permissions")
}

model Department {
  id          String                 @id @default(cuid())
  name        String                 @unique
  employees   Employee[]
  permissions DepartmentPermission[]
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  @@map("departments")
}

model Employee {
  id           String      @id @default(cuid())
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String      @unique @map("user_id")
  fullName     String      @map("full_name")
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  departmentId String?     @map("department_id")
  hireDate     DateTime    @map("hire_date") @db.Date
  manager    Employee?   @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  managerId  String?     @map("manager_id")
  phone      String?
  street     String?
  city       String?
  state      String?
  postalCode String?     @map("postal_code")
  country    String?
  reports               Employee[]                     @relation("EmployeeManager")
  timesheets            Timesheet[]
  profileUpdateRequests EmployeeProfileUpdateRequest[]
  organizations         Organization[]
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@map("employees")
}

enum EmployeeProfileUpdateRequestStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED

  @@map("employee_profile_update_request_status")
}

model EmployeeProfileUpdateRequest {
  id                 String                              @id @default(cuid())
  employee           Employee                            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId         String                              @map("employee_id")
  phone              String?
  street             String?
  city               String?
  state              String?
  postalCode         String?                             @map("postal_code")
  country            String?
  status             EmployeeProfileUpdateRequestStatus  @default(PENDING)
  rejectionReason    String?                             @map("rejection_reason")
  resolvedById       String?                             @map("resolved_by_id")
  workflowInstanceId String?                             @map("workflow_instance_id")
  createdAt          DateTime                            @default(now()) @map("created_at")
  updatedAt          DateTime                            @updatedAt @map("updated_at")

  @@map("employee_profile_update_requests")
}

model Timesheet {
  id                 String           @id @default(cuid())
  employee           Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId         String           @map("employee_id")
  weekStart          DateTime         @map("week_start") @db.Date
  rejectionReason    String?          @map("rejection_reason")
  status             TimesheetStatus  @default(draft)
  workflowInstanceId String?          @map("workflow_instance_id")
  submittedAt        DateTime?        @map("submitted_at")
  decidedAt          DateTime?        @map("decided_at")
  entries            TimesheetEntry[]
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@unique([employeeId, weekStart])
  @@index([status])
  @@index([workflowInstanceId])
  @@map("timesheets")
}

enum OrganizationStatus {
  active
  inactive
  archived
}

model Organization {
  id             String             @id @default(cuid())
  name           String
  legalName      String?            @map("legal_name")
  industry       String?
  taxId          String?            @map("tax_id")
  registrationNo String?            @map("registration_no")
  status         OrganizationStatus @default(active)
  email          String?
  phone          String?
  website        String?
  street         String?
  city           String?
  state          String?
  postalCode     String?            @map("postal_code")
  country        String?
  owner          Employee?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId        String?            @map("owner_id")
  statusChangeReason String?        @map("status_change_reason")
  workflowInstanceId String?        @map("workflow_instance_id")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  @@map("organizations")
}

model TimesheetEntry {
  id          String    @id @default(cuid())
  timesheet   Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  timesheetId String    @map("timesheet_id")
  date        DateTime  @db.Date
  hours       Decimal   @db.Decimal(4, 2)
  projectCode String?   @map("project_code")
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([timesheetId])
  @@map("timesheet_entries")
}
